---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const categories = ['system-design', 'architecture', 'programming'] as const;
  return categories.map((cat) => ({ params: { category: cat } }));
}

const { category } = Astro.params as { category: 'system-design' | 'architecture' | 'programming' };

const all = await getCollection('articles');
const articles = all
  .filter((a) => a.data.category === category)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const categoryMeta = {
  'system-design': { label: 'Thiết kế hệ thống', badge: 'badge-sd', dot: 'dot-sd' },
  'architecture':  { label: 'Kiến trúc',          badge: 'badge-arch', dot: 'dot-arch' },
  'programming':   { label: 'Lập trình',           badge: 'badge-prog', dot: 'dot-prog' },
} as const;

const meta = categoryMeta[category];

function formatDate(d: Date) {
  return d.toLocaleDateString('vi-VN', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<BaseLayout title={meta.label}>
  <style>
    .back {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: #4b5563;
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 500;
      margin-bottom: 2rem;
      transition: color 0.15s;
    }
    .back:hover { color: #e2e8f0; }
    .back svg { width: 14px; height: 14px; }

    .page-header { margin-bottom: 2.5rem; }

    .page-header h1 {
      font-size: 1.5rem;
      font-weight: 800;
      letter-spacing: -0.03em;
      color: #f1f5f9;
      margin-bottom: 0.35rem;
    }

    .page-header .count {
      color: #4b5563;
      font-size: 0.875rem;
    }

    .article-list {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .article-card {
      display: flex;
      gap: 1.25rem;
      padding: 1.2rem 0;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      text-decoration: none;
      color: inherit;
      transition: opacity 0.15s;
      align-items: flex-start;
    }

    .article-card:last-child { border-bottom: none; }
    .article-card:hover { opacity: 0.8; }
    .article-card:hover .article-title { color: #a78bfa; }

    .article-index {
      flex-shrink: 0;
      width: 28px;
      height: 28px;
      border-radius: 6px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.07);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.7rem;
      font-weight: 600;
      color: #4b5563;
      font-family: 'JetBrains Mono', monospace;
      margin-top: 2px;
    }

    .article-body { flex: 1; min-width: 0; }

    .article-date {
      color: #4b5563;
      font-size: 0.78rem;
      margin-bottom: 0.35rem;
    }

    .article-title {
      font-size: 1rem;
      font-weight: 600;
      color: #e2e8f0;
      line-height: 1.4;
      margin-bottom: 0.3rem;
      transition: color 0.15s;
    }

    .article-desc {
      color: #6b7280;
      font-size: 0.875rem;
      line-height: 1.55;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .tags {
      display: flex;
      gap: 0.35rem;
      flex-wrap: wrap;
      margin-top: 0.55rem;
    }

    .empty-state {
      text-align: center;
      padding: 4rem 0;
      color: #4b5563;
      font-size: 0.9rem;
    }
  </style>

  <a href="/" class="back">
    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M10 3L5 8l5 5" />
    </svg>
    Tất cả bài viết
  </a>

  <div class="page-header">
    <h1>
      <span class={`badge ${meta.badge}`} style="margin-bottom:0.6rem;">
        <span class={`badge-dot ${meta.dot}`}></span>
        {meta.label}
      </span>
      <br />{meta.label}
    </h1>
    <p class="count">{articles.length} bài viết</p>
  </div>

  {articles.length === 0 ? (
    <p class="empty-state">Chưa có bài viết nào trong chuyên mục này.</p>
  ) : (
    <div class="article-list">
      {articles.map((article, i) => (
        <a href={`/articles/${article.slug}`} class="article-card">
          <div class="article-index">{String(i + 1).padStart(2, '0')}</div>
          <div class="article-body">
            <div class="article-date">{formatDate(article.data.pubDate)}</div>
            <div class="article-title">{article.data.title}</div>
            <p class="article-desc">{article.data.description}</p>
            {article.data.tags && article.data.tags.length > 0 && (
              <div class="tags">
                {article.data.tags.slice(0, 4).map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </div>
        </a>
      ))}
    </div>
  )}
</BaseLayout>
