---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const articles = (await getCollection('articles')).sort(
    (a, b) => a.data.pubDate.getTime() - b.data.pubDate.getTime()
  );
  return articles.map((article, index) => ({
    params: { slug: article.slug },
    props: { 
      article,
      prevArticle: index > 0 ? articles[index - 1] : null,
      nextArticle: index < articles.length - 1 ? articles[index + 1] : null,
    },
  }));
}

const { article, prevArticle, nextArticle } = Astro.props;
const { Content } = await article.render();

const categoryMeta = {
  'system-design': { label: 'Thiết kế hệ thống', badge: 'badge-sd', dot: 'dot-sd', href: '/system-design' },
  'architecture':  { label: 'Kiến trúc',          badge: 'badge-arch', dot: 'dot-arch', href: '/architecture' },
  'programming':   { label: 'Lập trình',           badge: 'badge-prog', dot: 'dot-prog', href: '/programming' },
} as const;

const meta = categoryMeta[article.data.category];

function formatDate(d: Date) {
  return d.toLocaleDateString('vi-VN', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<BaseLayout title={article.data.title} description={article.data.description}>
  <style>
    .back {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: #4b5563;
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 500;
      margin-bottom: 2rem;
      transition: color 0.15s;
    }
    .back:hover { color: #e2e8f0; }
    .back svg { width: 14px; height: 14px; }

    .article-header { margin-bottom: 2rem; }

    .article-meta {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1rem;
      flex-wrap: wrap;
    }

    .article-date { color: #4b5563; font-size: 0.82rem; }

    h1 {
      font-size: 1.65rem;
      font-weight: 800;
      letter-spacing: -0.03em;
      line-height: 1.25;
      color: #f1f5f9;
      margin-bottom: 0.75rem;
    }

    .article-desc {
      color: #6b7280;
      font-size: 0.95rem;
      line-height: 1.65;
      padding-left: 1rem;
      border-left: 2px solid #8b5cf6;
    }

    .tags {
      display: flex;
      gap: 0.4rem;
      flex-wrap: wrap;
      margin-top: 1rem;
    }

    .divider {
      border: none;
      height: 1px;
      background: rgba(255,255,255,0.06);
      margin: 2rem 0;
    }

    /* ── Prose ── */
    .prose { color: #cbd5e1; }

    .prose h2 {
      font-size: 1.25rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: #f1f5f9;
      margin: 2.25rem 0 0.75rem;
      padding-bottom: 0.4rem;
      border-bottom: 1px solid rgba(255,255,255,0.06);
    }

    .prose h3 {
      font-size: 1.05rem;
      font-weight: 600;
      color: #e2e8f0;
      margin: 1.75rem 0 0.5rem;
    }

    .prose p { margin-bottom: 1.1rem; line-height: 1.8; }

    .prose ul, .prose ol {
      padding-left: 1.4rem;
      margin-bottom: 1.1rem;
    }

    .prose li { margin-bottom: 0.4rem; line-height: 1.7; }

    .prose strong { color: #f1f5f9; font-weight: 600; }

    .prose em { color: #a78bfa; font-style: normal; }

    .prose a {
      color: #a78bfa;
      text-decoration: underline;
      text-decoration-color: rgba(167,139,250,0.4);
      transition: text-decoration-color 0.15s;
    }
    .prose a:hover { text-decoration-color: #a78bfa; }

    /* inline code (not inside pre) */
    .prose :not(pre) > code {
      font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
      font-size: 0.855em;
      background: rgba(139,92,246,0.12);
      border: 1px solid rgba(139,92,246,0.22);
      color: #c4b5fd;
      padding: 0.15rem 0.45rem;
      border-radius: 4px;
    }

    /* Shiki code blocks */
    .prose pre {
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 10px;
      padding: 0;
      overflow-x: auto;
      margin: 1.25rem 0 1.5rem;
      font-size: 0.875rem;
      line-height: 1.65;
    }

    .prose pre > code {
      display: block;
      padding: 1.25rem 1.5rem;
      font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
      background: none !important;
      border: none;
      min-width: 100%;
      width: max-content;
    }

    /* Shiki wraps the pre in a div — fix its bg/radius */
    .prose .astro-code,
    .prose .shiki {
      border-radius: 10px;
      border: 1px solid rgba(255,255,255,0.08);
      margin: 1.25rem 0 1.5rem;
      font-size: 0.875rem;
      overflow-x: auto;
    }

    .prose .astro-code pre,
    .prose .shiki pre {
      border: none;
      border-radius: 0;
      margin: 0;
      padding: 1.25rem 1.5rem;
    }

    .prose blockquote {
      border-left: 2px solid #8b5cf6;
      padding: 0.1rem 0 0.1rem 1.25rem;
      margin: 1.5rem 0;
      color: #6b7280;
      font-style: italic;
    }

    .prose blockquote p { margin-bottom: 0; }

    .prose hr {
      border: none;
      height: 1px;
      background: rgba(255,255,255,0.06);
      margin: 2rem 0;
    }

    .prose table {
      width: 100%;
      border-collapse: collapse;
      margin: 1.25rem 0 1.5rem;
      font-size: 0.875rem;
    }

    .prose th {
      background: rgba(255,255,255,0.04);
      color: #e2e8f0;
      font-weight: 600;
      text-align: left;
      padding: 0.6rem 0.9rem;
      border-bottom: 1px solid rgba(255,255,255,0.09);
    }

    .prose td {
      padding: 0.55rem 0.9rem;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      color: #94a3b8;
    }

    .prose tr:last-child td { border-bottom: none; }

    .prose img {
      max-width: 100%;
      border-radius: 8px;
      border: 1px solid rgba(255,255,255,0.07);
    }

    /* ── Responsive Mobile ── */
    @media (max-width: 600px) {
      h1 {
        font-size: 1.45rem;
      }
      .article-meta {
        gap: 0.5rem;
        margin-bottom: 0.75rem;
      }
      .prose h2 {
        font-size: 1.15rem;
        margin: 2rem 0 0.75rem;
      }
      .prose h3 {
        font-size: 1rem;
        margin: 1.5rem 0 0.5rem;
      }
      .prose p {
        font-size: 0.95rem;
      }
      .prose pre {
        margin: 1rem -1.25rem 1.25rem;
        border-radius: 0;
        border-left: none;
        border-right: none;
      }
      .prose .astro-code,
      .prose .shiki {
        margin: 1rem -1.25rem 1.25rem;
        border-radius: 0;
        border-left: none;
        border-right: none;
      }
      .prose pre > code {
        padding: 1rem 1.25rem;
      }
      .prose .astro-code pre,
      .prose .shiki pre {
        padding: 1rem 1.25rem;
      }
      .prose blockquote {
        margin: 1.25rem 0;
        padding-left: 1rem;
      }
    }

    /* ── Pagination ── */
    .article-nav {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      margin-top: 4rem;
      padding-top: 2rem;
      border-top: 1px solid rgba(255,255,255,0.06);
    }

    .nav-btn {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      padding: 1rem;
      border-radius: 8px;
      background: rgba(255,255,255,0.02);
      border: 1px solid rgba(255,255,255,0.05);
      text-decoration: none;
      transition: background 0.15s, border-color 0.15s;
    }

    .nav-btn:hover {
      background: rgba(255,255,255,0.04);
      border-color: rgba(139,92,246,0.3);
    }

    .nav-btn.next { text-align: right; }
    .nav-btn.prev { text-align: left; }

    .nav-label {
      font-size: 0.75rem;
      font-weight: 600;
      color: #6b7280;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .nav-title {
      font-size: 0.9rem;
      font-weight: 600;
      color: #e2e8f0;
      line-height: 1.4;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    @media (max-width: 600px) {
      .article-nav {
        flex-direction: column;
        gap: 0.75rem;
      }
      .nav-btn.next, .nav-btn.prev {
        text-align: left;
      }
    }
  </style>

  <a href="/" class="back">
    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M10 3L5 8l5 5" />
    </svg>
    Tất cả bài viết
  </a>

  <div class="article-header">
    <div class="article-meta">
      <span class={`badge ${meta.badge}`}>
        <span class={`badge-dot ${meta.dot}`}></span>
        {meta.label}
      </span>
      <span class="article-date">{formatDate(article.data.pubDate)}</span>
    </div>

    <h1>{article.data.title}</h1>
    <p class="article-desc">{article.data.description}</p>

    {article.data.tags && article.data.tags.length > 0 && (
      <div class="tags">
        {article.data.tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}
  </div>

  <hr class="divider" />

  <div class="prose">
    <Content />
  </div>

  <div class="article-nav">
    {prevArticle ? (
      <a href={`/articles/${prevArticle.slug}`} class="nav-btn prev">
        <span class="nav-label">Bài trước</span>
        <span class="nav-title">{prevArticle.data.title}</span>
      </a>
    ) : <div></div>}
    
    {nextArticle ? (
      <a href={`/articles/${nextArticle.slug}`} class="nav-btn next">
        <span class="nav-label">Bài tiếp theo</span>
        <span class="nav-title">{nextArticle.data.title}</span>
      </a>
    ) : <div></div>}
  </div>
</BaseLayout>
