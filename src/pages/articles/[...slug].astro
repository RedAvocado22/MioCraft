---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  buildLocalArticleNumbers,
  formatArticleNumber,
  getPartNumber,
  sortArticles,
} from '../../utils/article-numbering';

export async function getStaticPaths() {
  const articles = (await getCollection('articles')).sort(
    sortArticles
  );
  const localNumbers = buildLocalArticleNumbers(articles);
  return articles.map((article, index) => {
    const currentTags = new Set(article.data.tags ?? []);
    const relatedArticles = articles
      .filter(a => a.slug !== article.slug)
      .map(a => ({ a, score: (a.data.tags ?? []).filter(t => currentTags.has(t)).length }))
      .filter(r => r.score > 0)
      .sort((a, b) => b.score - a.score)
      .slice(0, 3)
      .map(r => ({ article: r.a, localNumber: localNumbers.get(r.a.slug) }));
    return {
      params: { slug: article.slug },
      props: {
        article,
        prevArticle: index > 0 ? articles[index - 1] : null,
        nextArticle: index < articles.length - 1 ? articles[index + 1] : null,
        relatedArticles,
      },
    };
  });
}

const { article, prevArticle, nextArticle, relatedArticles } = Astro.props;
const seriesHref = article.data.series?.includes('Behind the Tech') ? '/behind-the-tech' : '/code-co-nghe';
const { Content, headings } = await article.render();
const tocHeadings = headings.filter(h => h.depth === 2 || h.depth === 3);

const categoryMeta = {
  'system-design': { label: 'Thiết kế hệ thống', badge: 'badge-sd', dot: 'dot-sd', href: '/system-design' },
  'architecture':  { label: 'Kiến trúc',          badge: 'badge-arch', dot: 'dot-arch', href: '/architecture' },
  'programming':   { label: 'Lập trình',           badge: 'badge-prog', dot: 'dot-prog', href: '/programming' },
} as const;

const meta = categoryMeta[article.data.category];

// Reading time estimate (~200 words/min)
const wordCount = article.body.split(/\s+/).length;
const readingTime = Math.max(1, Math.ceil(wordCount / 200));

function formatDate(d: Date) {
  return d.toLocaleDateString('vi-VN', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<BaseLayout title={article.data.title} description={article.data.description} ogType="article">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": article.data.title,
      "description": article.data.description,
      "datePublished": article.data.pubDate.toISOString(),
      "url": new URL(`/articles/${article.slug}`, Astro.site).toString(),
      "inLanguage": "vi",
      "author": { "@type": "Person", "name": "RedAvocado22", "url": "https://github.com/RedAvocado22" },
      "publisher": { "@type": "Organization", "name": "MioCraft", "url": Astro.site?.toString() },
      "keywords": (article.data.tags ?? []).join(', ')
    })} />
  </Fragment>
  <style>
    /* ── Reading Progress Bar ── */
    .reading-progress {
      position: fixed;
      top: 58px;
      left: 0;
      right: 0;
      height: 2px;
      background: rgba(255,255,255,0.04);
      z-index: 49;
      pointer-events: none;
    }
    .reading-progress-bar {
      height: 100%;
      width: 0%;
      background: linear-gradient(90deg, #7c3aed, #8b5cf6, #a78bfa, #c084fc);
      border-radius: 0 2px 2px 0;
      transition: width 80ms linear;
    }

    /* ── Back to top ── */
    .back-to-top {
      position: fixed;
      bottom: 2rem;
      right: 1.5rem;
      width: 38px;
      height: 38px;
      background: rgba(139,92,246,0.12);
      border: 1px solid rgba(139,92,246,0.25);
      border-radius: 8px;
      color: #a78bfa;
      font-size: 1rem;
      line-height: 1;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      transform: translateY(10px);
      transition: opacity 0.2s, transform 0.2s, background 0.15s, border-color 0.15s;
      pointer-events: none;
      z-index: 40;
    }
    .back-to-top.visible {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }
    .back-to-top:hover {
      background: rgba(139,92,246,0.22);
      border-color: rgba(139,92,246,0.45);
    }

    /* ── Back link ── */
    .back {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      color: #4b5563;
      text-decoration: none;
      font-size: 0.85rem;
      font-weight: 500;
      margin-bottom: 2rem;
      transition: color 0.15s;
    }
    .back:hover { color: #e2e8f0; }
    .back svg { width: 14px; height: 14px; }

    /* ── Article header ── */
    .article-header { margin-bottom: 2rem; }

    .article-meta {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1rem;
      flex-wrap: wrap;
    }

    .article-date { color: #4b5563; font-size: 0.82rem; }

    .reading-time {
      color: #4b5563;
      font-size: 0.82rem;
    }
    .reading-time::before { content: '·'; margin-right: 0.35rem; }

    h1 {
      font-size: 1.65rem;
      font-weight: 800;
      letter-spacing: -0.03em;
      line-height: 1.25;
      color: #f1f5f9;
      margin-bottom: 0.75rem;
    }

    .article-desc {
      color: #6b7280;
      font-size: 0.95rem;
      line-height: 1.65;
      padding-left: 1rem;
      border-left: 2px solid #8b5cf6;
    }

    .tags {
      display: flex;
      gap: 0.4rem;
      flex-wrap: wrap;
      margin-top: 1rem;
    }

    .divider {
      border: none;
      height: 1px;
      background: rgba(255,255,255,0.06);
      margin: 2rem 0;
    }

    /* ── Table of Contents ── */
    .toc {
      background: rgba(255,255,255,0.02);
      border: 1px solid rgba(255,255,255,0.07);
      border-left: 2px solid #8b5cf6;
      border-radius: 8px;
      padding: 1rem 1.25rem;
      margin-bottom: 2rem;
      font-size: 0.82rem;
    }

    .toc-title {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #8b5cf6;
      margin-bottom: 0.6rem;
    }

    .toc ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .toc li a {
      color: #6b7280;
      text-decoration: none;
      line-height: 1.5;
      transition: color 0.12s, background 0.12s;
      display: block;
      border-radius: 4px;
      padding: 0.15rem 0.4rem;
      margin: 0 -0.4rem;
    }
    .toc li a:hover { color: #a78bfa; }
    .toc li a.active {
      color: #a78bfa;
      background: rgba(139,92,246,0.08);
    }
    .toc li.toc-h3 { padding-left: 0.9rem; }
    .toc li.toc-h3 a { font-size: 0.78rem; }

    /* Desktop: floating sidebar TOC */
    @media (min-width: 1280px) {
      .toc {
        position: fixed;
        top: 90px;
        left: calc(50% - 380px - 60px - 200px);
        width: 200px;
        margin-bottom: 0;
        max-height: calc(100vh - 110px);
        overflow-y: auto;
        scrollbar-width: none;
      }
      .toc::-webkit-scrollbar { display: none; }
    }

    /* ── Prose ── */
    .prose { color: #cbd5e1; }

    .prose h2 {
      font-size: 1.25rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      color: #f1f5f9;
      margin: 2.25rem 0 0.75rem;
      padding-bottom: 0.4rem;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      scroll-margin-top: 80px;
    }

    .prose h3 {
      font-size: 1.05rem;
      font-weight: 600;
      color: #e2e8f0;
      margin: 1.75rem 0 0.5rem;
      scroll-margin-top: 80px;
    }

    .prose p { margin-bottom: 1.1rem; line-height: 1.8; }

    .prose ul, .prose ol {
      padding-left: 1.4rem;
      margin-bottom: 1.1rem;
    }
    .prose li { margin-bottom: 0.4rem; line-height: 1.7; }

    .prose strong { color: #f1f5f9; font-weight: 600; }
    .prose em { color: #a78bfa; font-style: normal; }

    .prose a {
      color: #a78bfa;
      text-decoration: underline;
      text-decoration-color: rgba(167,139,250,0.4);
      transition: text-decoration-color 0.15s;
    }
    .prose a:hover { text-decoration-color: #a78bfa; }

    /* Inline code */
    .prose :not(pre) > code {
      font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
      font-size: 0.855em;
      background: rgba(139,92,246,0.12);
      border: 1px solid rgba(139,92,246,0.22);
      color: #c4b5fd;
      padding: 0.15rem 0.45rem;
      border-radius: 4px;
    }

    /* Shiki code blocks */
    .prose pre {
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 10px;
      padding: 0;
      overflow-x: auto;
      margin: 1.25rem 0 1.5rem;
      font-size: 0.875rem;
      line-height: 1.65;
    }

    .prose pre > code {
      display: block;
      padding: 1.25rem 1.5rem;
      font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
      background: none !important;
      border: none;
      min-width: 100%;
      width: max-content;
    }

    /* Shiki wraps the pre in a div — fix its bg/radius */
    .prose .astro-code,
    .prose .shiki {
      border-radius: 10px;
      border: 1px solid rgba(255,255,255,0.08);
      margin: 1.25rem 0 1.5rem;
      font-size: 0.875rem;
      overflow-x: auto;
    }

    .prose .astro-code pre,
    .prose .shiki pre {
      border: none;
      border-radius: 0;
      margin: 0;
      padding: 1.25rem 1.5rem;
    }



    /* ── Blockquote redesign ── */
    .prose blockquote {
      border-left: 2px solid #8b5cf6;
      padding: 1rem 1.25rem 1rem 1.5rem;
      margin: 1.75rem 0;
      color: #6b7280;
      font-style: italic;
      background: rgba(139,92,246,0.05);
      border-radius: 0 8px 8px 0;
      position: relative;
      overflow: hidden;
    }
    .prose blockquote::before {
      content: '\201C';
      position: absolute;
      top: -0.75rem;
      left: 0.6rem;
      font-size: 3rem;
      line-height: 1;
      color: rgba(139,92,246,0.2);
      font-family: Georgia, serif;
      pointer-events: none;
    }
    .prose blockquote p {
      margin-bottom: 0;
      padding-top: 0.5rem;
    }

    .prose hr {
      border: none;
      height: 1px;
      background: rgba(255,255,255,0.06);
      margin: 2rem 0;
    }

    .prose table {
      width: 100%;
      border-collapse: collapse;
      margin: 1.25rem 0 1.5rem;
      font-size: 0.875rem;
    }
    .prose th {
      background: rgba(255,255,255,0.04);
      color: #e2e8f0;
      font-weight: 600;
      text-align: left;
      padding: 0.6rem 0.9rem;
      border-bottom: 1px solid rgba(255,255,255,0.09);
    }
    .prose td {
      padding: 0.55rem 0.9rem;
      border-bottom: 1px solid rgba(255,255,255,0.05);
      color: #94a3b8;
    }
    .prose tr:last-child td { border-bottom: none; }

    .prose img {
      max-width: 100%;
      border-radius: 8px;
      border: 1px solid rgba(255,255,255,0.07);
    }

    /* ── Pagination ── */
    .article-nav {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      margin-top: 4rem;
      padding-top: 2rem;
      border-top: 1px solid rgba(255,255,255,0.06);
    }

    .nav-btn {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      padding: 1rem;
      border-radius: 8px;
      background: rgba(255,255,255,0.02);
      border: 1px solid rgba(255,255,255,0.05);
      text-decoration: none;
      transition: background 0.15s, border-color 0.15s;
    }
    .nav-btn:hover {
      background: rgba(255,255,255,0.04);
      border-color: rgba(139,92,246,0.3);
    }
    .nav-btn.next { text-align: right; }
    .nav-btn.prev { text-align: left; }

    .nav-label {
      font-size: 0.75rem;
      font-weight: 600;
      color: #6b7280;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    .nav-title {
      font-size: 0.9rem;
      font-weight: 600;
      color: #e2e8f0;
      line-height: 1.4;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    /* ── Related Articles ── */
    .related-articles {
      margin-top: 3rem;
      padding-top: 2rem;
      border-top: 1px solid rgba(255,255,255,0.06);
    }
    .related-title {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #6b7280;
      margin-bottom: 0.75rem;
    }
    .related-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0.75rem;
    }
    .related-card {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      padding: 0.85rem 1rem;
      border-radius: 8px;
      background: rgba(255,255,255,0.02);
      border: 1px solid rgba(255,255,255,0.05);
      text-decoration: none;
      transition: background 0.15s, border-color 0.15s;
    }
    .related-card:hover {
      background: rgba(255,255,255,0.04);
      border-color: rgba(139,92,246,0.3);
    }
    .related-card-num {
      font-size: 0.65rem;
      font-weight: 600;
      color: #4b5563;
      letter-spacing: 0.05em;
    }
    .related-card-title {
      font-size: 0.82rem;
      font-weight: 600;
      color: #cbd5e1;
      line-height: 1.4;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .related-card:hover .related-card-title { color: #a78bfa; }
    .related-card-series {
      font-size: 0.7rem;
      color: #4b5563;
      margin-top: auto;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    /* ── Read Badge ── */
    .read-badge {
      display: none;
      align-items: center;
      gap: 0.3rem;
      font-size: 0.75rem;
      font-weight: 600;
      color: #34d399;
      background: rgba(52,211,153,0.08);
      border: 1px solid rgba(52,211,153,0.2);
      border-radius: 4px;
      padding: 0.15rem 0.5rem;
    }
    .read-badge.visible { display: flex; }

    /* ── Mobile ── */
    @media (max-width: 600px) {
      .related-grid { grid-template-columns: 1fr; }
      h1 { font-size: 1.45rem; }
      .article-meta { gap: 0.5rem; margin-bottom: 0.75rem; }
      .prose h2 { font-size: 1.15rem; margin: 2rem 0 0.75rem; }
      .prose h3 { font-size: 1rem; margin: 1.5rem 0 0.5rem; }
      .prose p { font-size: 0.95rem; }
      .prose pre {
        margin: 1rem -1.25rem 1.25rem;
        border-radius: 0;
        border-left: none;
        border-right: none;
      }
      .prose .astro-code,
      .prose .shiki {
        margin: 1rem -1.25rem 1.25rem;
        border-radius: 0;
        border-left: none;
        border-right: none;
      }
      .prose pre > code { padding: 1rem 1.25rem; }
      .prose .astro-code pre,
      .prose .shiki pre { padding: 1rem 1.25rem; }
      .prose blockquote { margin: 1.25rem 0; padding-left: 1rem; }
      .article-nav { flex-direction: column; gap: 0.75rem; }
      .nav-btn.next, .nav-btn.prev { text-align: left; }
      .back-to-top { bottom: 1rem; right: 1rem; }
    }
  </style>

  <!-- Reading Progress Bar -->
  <div class="reading-progress" aria-hidden="true">
    <div class="reading-progress-bar" id="reading-progress-bar"></div>
  </div>

  <!-- Back to top -->
  <button class="back-to-top" id="back-to-top" aria-label="Về đầu trang">↑</button>

  <a href={seriesHref} class="back">
    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M10 3L5 8l5 5" />
    </svg>
    Tất cả bài viết
  </a>

  <div class="article-header" data-slug={article.slug}>
    <div class="article-meta">
      <span class="read-badge" id="read-badge">✓ Đã đọc</span>
      <span class={`badge ${meta.badge}`}>
        <span class={`badge-dot ${meta.dot}`}></span>
        {meta.label}
      </span>
      <span class="article-date">{formatDate(article.data.pubDate)}</span>
      <span class="reading-time">{readingTime} phút đọc</span>
    </div>

    <h1>{article.data.title}</h1>
    <p class="article-desc">{article.data.description}</p>

    {article.data.tags && article.data.tags.length > 0 && (
      <div class="tags">
        {article.data.tags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>
    )}
  </div>

  <hr class="divider" />

  {tocHeadings.length >= 3 && (
    <nav class="toc" id="toc">
      <p class="toc-title">Nội dung</p>
      <ul>
        {tocHeadings.map(h => (
          <li class={h.depth === 3 ? 'toc-h3' : ''}>
            <a href={`#${h.slug}`} data-slug={h.slug}>{h.text}</a>
          </li>
        ))}
      </ul>
    </nav>
  )}

  <div class="prose" id="article-prose">
    <Content />
  </div>

  {relatedArticles.length > 0 && (
    <div class="related-articles">
      <p class="related-title">Bài liên quan</p>
      <div class="related-grid">
        {relatedArticles.map(r => {
          const partNumber = getPartNumber(r.article.data.series);
          const numMatch = r.article.slug.match(/^(?:bai|btt)-(\d+)-/);
          const num = numMatch ? numMatch[1] : '??';
          const numberLabel = partNumber !== null
            ? `P${String(partNumber).padStart(2, '0')} · Bài ${formatArticleNumber(r.localNumber)}`
            : `Bài ${num}`;
          const seriesShort = r.article.data.series ? r.article.data.series.replace(/^Phần \d+:\s*/, '') : '';
          return (
            <a href={`/articles/${r.article.slug}`} class="related-card">
              <span class="related-card-num">{numberLabel}</span>
              <span class="related-card-title">{r.article.data.title}</span>
              {seriesShort && <span class="related-card-series">{seriesShort}</span>}
            </a>
          );
        })}
      </div>
    </div>
  )}

  <div class="article-nav">
    {prevArticle ? (
      <a href={`/articles/${prevArticle.slug}`} class="nav-btn prev">
        <span class="nav-label">← Bài trước</span>
        <span class="nav-title">{prevArticle.data.title}</span>
      </a>
    ) : <div></div>}

    {nextArticle ? (
      <a href={`/articles/${nextArticle.slug}`} class="nav-btn next">
        <span class="nav-label">Bài tiếp theo →</span>
        <span class="nav-title">{nextArticle.data.title}</span>
      </a>
    ) : <div></div>}
  </div>

<script>
  // ── Reading Progress Bar ──
  const bar = document.getElementById('reading-progress-bar');
  function updateProgress() {
    if (!bar) return;
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const pct = docHeight > 0 ? Math.min(100, (scrollTop / docHeight) * 100) : 0;
    bar.style.width = pct + '%';
  }
  window.addEventListener('scroll', updateProgress, { passive: true });
  updateProgress();

  // ── Back to top ──
  const btt = document.getElementById('back-to-top');
  function updateBtt() {
    if (!btt) return;
    btt.classList.toggle('visible', window.scrollY > 400);
  }
  window.addEventListener('scroll', updateBtt, { passive: true });
  btt?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));



  // ── TOC Active Heading Highlight ──
  const tocLinks = document.querySelectorAll('.toc a[data-slug]');
  if (tocLinks.length > 0) {
    const headingEls = Array.from(document.querySelectorAll('.prose h2, .prose h3'));
    
    let activeId = '';
    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          activeId = entry.target.getAttribute('id') || '';
          updateToc();
        }
      });
    }, {
      rootMargin: '-10% 0% -75% 0%',
      threshold: 0,
    });
    headingEls.forEach(el => observer.observe(el));

    function updateToc() {
      // If user scrolled to the absolute bottom, activate the last heading
      const isAtBottom = Math.ceil(window.innerHeight + window.scrollY) >= document.documentElement.scrollHeight - 50;
      let targetId = activeId;
      
      if (isAtBottom && headingEls.length > 0) {
        targetId = headingEls[headingEls.length - 1].getAttribute('id') || '';
      }

      tocLinks.forEach(link => {
        link.classList.toggle('active', link.getAttribute('data-slug') === targetId);
      });
    }

    window.addEventListener('scroll', updateToc, { passive: true });
    // Run once on load to set initial state
    updateToc();
  }

  // ── Read Tracking ──
  const STORAGE_KEY = 'mio_read';
  const currentSlug = document.querySelector('.article-header')?.getAttribute('data-slug') ?? '';

  function getReadSlugs() {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); } catch { return []; }
  }
  function markRead() {
    const slugs = getReadSlugs();
    if (currentSlug && !slugs.includes(currentSlug)) {
      slugs.push(currentSlug);
      localStorage.setItem(STORAGE_KEY, JSON.stringify(slugs));
    }
    document.getElementById('read-badge')?.classList.add('visible');
  }

  if (currentSlug && getReadSlugs().includes(currentSlug)) {
    document.getElementById('read-badge')?.classList.add('visible');
  }

  let readMarked = !currentSlug || getReadSlugs().includes(currentSlug);
  window.addEventListener('scroll', () => {
    if (readMarked) return;
    const total = document.documentElement.scrollHeight - window.innerHeight;
    if (total > 0 && window.scrollY / total >= 0.8) {
      readMarked = true;
      markRead();
    }
  }, { passive: true });
</script>
</BaseLayout>
