---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const articles = await getCollection('articles');
const cstCount = articles.filter(a => !a.data.series || a.data.series.match(/^Phần \d+:/)).length;
const bttCount = articles.filter(a => a.data.series?.includes('Behind the Tech')).length;
---

<BaseLayout title="Trang chủ">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "MioCraft",
      "url": Astro.site?.toString(),
      "description": "Kiến thức lập trình & thiết kế hệ thống tiếng Việt",
      "inLanguage": "vi"
    })} />
  </Fragment>

  <style>
    .landing {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      margin-top: 2rem;
    }

    .eyebrow {
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .eyebrow::before {
      content: '';
      display: inline-block;
      width: 18px;
      height: 2px;
      background: var(--accent);
      border-radius: 1px;
    }

    .series-card {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      padding: 1.5rem;
      border-radius: 10px;
      background: rgba(255,255,255,0.02);
      border: 1px solid rgba(255,255,255,0.06);
      text-decoration: none;
      transition: background 0.15s, border-color 0.15s;
    }
    .series-card:hover {
      background: rgba(255,255,255,0.04);
      border-color: rgba(139,92,246,0.35);
    }

    .series-label {
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
    }

    .series-title {
      font-size: 1.2rem;
      font-weight: 800;
      color: #f1f5f9;
      letter-spacing: -0.02em;
      line-height: 1.3;
    }

    .series-desc {
      color: #6b7280;
      font-size: 0.82rem;
      line-height: 1.6;
    }

    .series-meta {
      font-size: 0.72rem;
      color: #374151;
      margin-top: 0.25rem;
    }

    .series-arrow {
      font-size: 0.85rem;
      color: #4b5563;
      margin-top: auto;
      transition: color 0.15s, transform 0.15s;
      display: inline-block;
    }
    .series-card:hover .series-arrow {
      color: #a78bfa;
      transform: translateX(3px);
    }
  </style>

  <p class="eyebrow">MioCraft / knowledge-base</p>

  <div class="landing">
    <a href="/code-song-ton" class="series-card">
      <span class="series-label">Series 01</span>
      <span class="series-title">Code Sống Sót</span>
      <span class="series-desc">Từ project sinh viên đến production-ready — system design, architecture, backend patterns, và những thứ không ai dạy trong trường.</span>
      <span class="series-meta">{cstCount} bài · 12 phần</span>
      <span class="series-arrow">→</span>
    </a>

    <a href="/behind-the-tech" class="series-card">
      <span class="series-label">Series 02</span>
      <span class="series-title">Behind the Tech</span>
      <span class="series-desc">Mày dùng nó hàng ngày. Nhưng mày có biết nó làm thế nào không? — internals của những thứ quen thuộc nhất.</span>
      <span class="series-meta">{bttCount > 0 ? `${bttCount} bài` : 'Sắp ra mắt'}</span>
      <span class="series-arrow">→</span>
    </a>
  </div>
</BaseLayout>
