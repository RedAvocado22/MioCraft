---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  buildLocalArticleNumbers,
  formatArticleNumber,
  getLatestDate,
  sortLatestArticles,
} from '../utils/article-numbering';

const articles = await getCollection('articles');
const cstCount = articles.filter(a => !a.data.series || a.data.series.match(/^Phần \d+:/)).length;
const bttCount = articles.filter(a => a.data.series?.includes('Behind the Tech')).length;
const localNumbers = buildLocalArticleNumbers(articles);
const latestArticles = [...articles].sort(sortLatestArticles).slice(0, 5);

function formatSeries(series?: string) {
  const match = series?.match(/^Phần (\d+):\s*(.*)$/);
  if (match) return `P${match[1].padStart(2, '0')} · ${match[2]}`;
  return series ?? 'Khác';
}

function formatDate(date: Date) {
  return date.toLocaleDateString('vi-VN', { day: 'numeric', month: 'short', year: 'numeric' });
}
---

<BaseLayout title="Trang chủ">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "MioCraft",
      "url": Astro.site?.toString(),
      "description": "Kiến thức lập trình & thiết kế hệ thống tiếng Việt",
      "inLanguage": "vi"
    })} />
  </Fragment>

  <style>
    .landing {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      margin-top: 2rem;
    }

    .eyebrow {
      font-size: 0.7rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1.5rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .eyebrow::before {
      content: '';
      display: inline-block;
      width: 18px;
      height: 2px;
      background: var(--accent);
      border-radius: 1px;
    }

    .series-card {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
      padding: 1.5rem;
      border-radius: 10px;
      background: rgba(255,255,255,0.02);
      border: 1px solid rgba(255,255,255,0.06);
      text-decoration: none;
      transition: background 0.15s, border-color 0.15s;
    }
    .series-card:hover {
      background: rgba(255,255,255,0.04);
      border-color: rgba(139,92,246,0.35);
    }

    .series-label {
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--accent);
    }

    .series-title {
      font-size: 1.2rem;
      font-weight: 800;
      color: #f1f5f9;
      letter-spacing: -0.02em;
      line-height: 1.3;
    }

    .series-desc {
      color: #6b7280;
      font-size: 0.82rem;
      line-height: 1.6;
    }

    .series-meta {
      font-size: 0.72rem;
      color: #374151;
      margin-top: 0.25rem;
    }

    .series-arrow {
      font-size: 0.85rem;
      color: #4b5563;
      margin-top: auto;
      transition: color 0.15s, transform 0.15s;
      display: inline-block;
    }
    .series-card:hover .series-arrow {
      color: #a78bfa;
      transform: translateX(3px);
    }

    .author-card {
      display: flex;
      align-items: center;
      gap: 1rem;
      padding: 1.1rem 1.25rem;
      border-radius: 10px;
      background: rgba(255,255,255,0.015);
      border: 1px solid rgba(255,255,255,0.06);
      text-decoration: none;
      color: inherit;
      margin-top: 0.5rem;
      transition: background 0.15s, border-color 0.15s;
    }
    .author-card:hover {
      background: rgba(139,92,246,0.06);
      border-color: rgba(139,92,246,0.2);
    }
    .author-avatar {
      width: 38px;
      height: 38px;
      border-radius: 50%;
      border: 1px solid rgba(255,255,255,0.1);
      flex-shrink: 0;
    }
    .author-info { flex: 1; min-width: 0; }
    .author-name {
      font-size: 0.85rem;
      font-weight: 700;
      color: #e2e8f0;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .author-name svg { color: #6b7280; }
    .author-bio {
      font-size: 0.75rem;
      color: #4b5563;
      margin-top: 0.15rem;
    }

    .latest-preview {
      padding: 1.25rem;
      border-radius: 10px;
      background: rgba(139,92,246,0.06);
      border: 1px solid rgba(139,92,246,0.18);
      text-decoration: none;
      color: inherit;
      transition: background 0.15s, border-color 0.15s;
    }
    .latest-preview:hover {
      background: rgba(139,92,246,0.1);
      border-color: rgba(139,92,246,0.35);
    }
    .latest-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 0.8rem;
    }
    .latest-title {
      color: #f1f5f9;
      font-size: 0.95rem;
      font-weight: 800;
    }
    .latest-link {
      color: #a78bfa;
      font-size: 0.72rem;
      white-space: nowrap;
    }
    .latest-list {
      display: flex;
      flex-direction: column;
      gap: 0.55rem;
    }
    .latest-item {
      display: flex;
      align-items: baseline;
      gap: 0.6rem;
      min-width: 0;
    }
    .latest-item-index {
      color: #8b5cf6;
      font-size: 0.68rem;
      flex-shrink: 0;
    }
    .latest-item-body {
      min-width: 0;
      flex: 1;
    }
    .latest-item-name {
      color: #cbd5e1;
      font-size: 0.78rem;
      line-height: 1.45;
      display: block;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .latest-item-meta {
      color: #6b7280;
      font-size: 0.66rem;
      display: block;
      margin-top: 0.1rem;
    }
  </style>

  <p class="eyebrow">MioCraft / knowledge-base</p>

  <div class="landing">
    <a href="/latest" class="latest-preview">
      <div class="latest-header">
        <span class="latest-title">Latest · Bài mới cập nhật</span>
        <span class="latest-link">Xem tất cả →</span>
      </div>
      <div class="latest-list">
        {latestArticles.map((article) => (
          <div class="latest-item">
            <span class="latest-item-index">{formatArticleNumber(localNumbers.get(article.slug))}</span>
            <span class="latest-item-body">
              <span class="latest-item-name">{article.data.title}</span>
              <span class="latest-item-meta">{formatSeries(article.data.series)} · {formatDate(getLatestDate(article))}</span>
            </span>
          </div>
        ))}
      </div>
    </a>

    <a href="/code-co-nghe" class="series-card">
      <span class="series-label">Series 01</span>
      <span class="series-title">Những Điều Mình Học Được</span>
      <span class="series-desc">Ghi chép cá nhân về lập trình, kiến trúc phần mềm và system design — những điều mình đã đọc, thử nghiệm và muốn lưu lại.</span>
      <span class="series-meta">{cstCount} bài · 12 phần</span>
      <span class="series-arrow">→</span>
    </a>

    <a href="/behind-the-tech" class="series-card">
      <span class="series-label">Series 02</span>
      <span class="series-title">Behind the Tech</span>
      <span class="series-desc">Google tìm kết quả trong 0.3 giây. Zalo biết bạn online. Dark mode không chỉ đổi màu. Đây là cách chúng hoạt động.</span>
      <span class="series-meta">{bttCount > 0 ? `${bttCount} bài` : 'Sắp ra mắt'}</span>
      <span class="series-arrow">→</span>
    </a>

    <a href="https://github.com/RedAvocado22" target="_blank" rel="noopener noreferrer" class="author-card">
      <img src="https://github.com/RedAvocado22.png?size=80" alt="RedAvocado22" class="author-avatar" loading="lazy" />
      <div class="author-info">
        <div class="author-name">
          <svg viewBox="0 0 16 16" width="13" height="13" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          @RedAvocado22
        </div>
        <div class="author-bio">Tác giả · github.com/RedAvocado22</div>
      </div>
    </a>
  </div>
</BaseLayout>
